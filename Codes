	}
	
public static void maxSubArraySum(int[] arr) {
       int currentSum=0;
       int maxSum=0;
       for(int num:arr){
           currentSum+=num;
           maxSum=Math.max(currentSum,maxSum);
           if(currentSum<0){
               currentSum=0;
           }
       }
       System.out.println("maxSubArraySum : "+maxSum); 
}
}

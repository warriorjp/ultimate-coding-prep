✅ Majority element: 

int arr[] ={2,3,3,3,1,1,3,1,3};
class Solution {
    public int majorityElement(int[] nums) {
        int candidate = 0 ,freq =0;
        for(int num : nums){
            if(freq == 0){
                candidate = num;
            }
            if(num == candidate){
                freq++;
            }else{
                freq--;
            }
        }
        return candidate;
    }
}

